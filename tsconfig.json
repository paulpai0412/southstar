{
  // Root Next app has been retired. The active web app is under ./web and is
  // checked with `tsc -p web/tsconfig.json --noEmit`.
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true
  },
  "files": [
    "types/root-typecheck.d.ts"
  ],
  "exclude": [
    "node_modules",
    "web",
    "app",
    "components",
    "lib",
    ".next",
    ".southstar"
  ]
}
