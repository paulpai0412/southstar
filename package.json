{
  "name": "@southstar/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "southstar": "src/cli/entrypoint.ts",
    "southstar-agent-runner": "src/v2/agent-runner/cli.ts"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "test": "tsx tests/index.test.ts",
    "test:v2": "tsx tests/v2/index.test.ts",
    "test:e2e:real": "tsx tests/e2e-real/index.test.ts",
    "test:e2e:productized-ui": "tsx tests/e2e-real/productized-ui-library-planner-real.test.ts",
    "test:e2e:design-library-real": "tsx tests/e2e-real/design-library-template-real.test.ts",
    "test:e2e:ui": "tsx tests/e2e-ui/index.test.ts",
    "web:dev": "next dev -p 3030 --webpack",
    "web:build": "next build --webpack",
    "web:start": "next start -p 3030",
    "southstar:v2": "tsx src/v2/cli.ts",
    "southstar": "tsx src/cli/entrypoint.ts"
  },
  "c8": {
    "all": true,
    "include": [
      "src/runtime/**/*.ts",
      "src/adapters/**/*.ts",
      "src/cli/**/*.ts",
      "src/config/**/*.ts",
      "src/intake/**/*.ts",
      "src/types/**/*.ts"
    ],
    "exclude": [
      "tests/**",
      "coverage/**"
    ],
    "reporter": [
      "text",
      "json-summary",
      "lcov"
    ],
    "reports-dir": "coverage",
    "check-coverage": true,
    "lines": 85,
    "branches": 85,
    "functions": 85,
    "statements": 85
  },
  "optionalDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@openai/codex-sdk": "^0.135.0",
    "@opencode-ai/sdk": "^1.15.12"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
