{
  "name": "@southstar/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "southstar": "src/cli/entrypoint.ts",
    "southstar-agent-runner": "src/v2/agent-runner/cli.ts"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "test": "tsx tests/index.test.ts",
    "test:v2": "tsx tests/v2/index.test.ts",
    "test:e2e:real": "tsx tests/e2e-postgres/index.test.ts",
    "test:e2e:legacy-sqlite": "tsx tests/e2e-legacy-sqlite/index.test.ts",
    "test:e2e:productized-ui": "tsx tests/e2e-legacy-sqlite/productized-ui-library-planner-real.test.ts",
    "test:e2e:design-library-real": "tsx tests/e2e-legacy-sqlite/design-library-template-real.test.ts",
    "test:postgres": "tsx tests/v2/postgres-store.test.ts",
    "test:e2e:postgres": "tsx tests/e2e-postgres/index.test.ts",
    "test:e2e:postgres:00": "tsx tests/e2e-postgres/cases/00-infra-preflight.test.ts",
    "test:e2e:postgres:01": "tsx tests/e2e-postgres/cases/01-db-schema-init.test.ts",
    "test:e2e:postgres:02": "tsx tests/e2e-postgres/cases/02-runtime-api-contract.test.ts",
    "test:e2e:postgres:03": "tsx tests/e2e-postgres/cases/03-normal-software-run.test.ts",
    "test:e2e:postgres:04": "tsx tests/e2e-postgres/cases/04-artifact-repair-recovery.test.ts",
    "test:e2e:postgres:05": "tsx tests/e2e-postgres/cases/05-session-recovery.test.ts",
    "test:e2e:postgres:06": "tsx tests/e2e-postgres/cases/06-executor-reconcile.test.ts",
    "test:e2e:postgres:07": "tsx tests/e2e-postgres/cases/07-evolution-learning.test.ts",
    "test:e2e:postgres:08": "tsx tests/e2e-postgres/cases/08-evolution-sandbox-baseline-candidate.test.ts",
    "test:e2e:postgres:09": "tsx tests/e2e-postgres/cases/09-regression-rollback.test.ts",
    "test:e2e:postgres:10": "tsx tests/e2e-postgres/cases/10-managed-brain-crash-wake.test.ts",
    "test:e2e:postgres:11": "tsx tests/e2e-postgres/cases/11-managed-hand-reprovision.test.ts",
    "test:e2e:ui": "tsx tests/e2e-ui/index.test.ts",
    "web:dev": "next dev -p 3030 --webpack",
    "web:build": "next build --webpack",
    "web:start": "next start -p 3030",
    "southstar:v2": "tsx src/v2/cli.ts",
    "southstar": "tsx src/cli/entrypoint.ts"
  },
  "c8": {
    "all": true,
    "include": [
      "src/runtime/**/*.ts",
      "src/adapters/**/*.ts",
      "src/cli/**/*.ts",
      "src/config/**/*.ts",
      "src/intake/**/*.ts",
      "src/types/**/*.ts"
    ],
    "exclude": [
      "tests/**",
      "coverage/**"
    ],
    "reporter": [
      "text",
      "json-summary",
      "lcov"
    ],
    "reports-dir": "coverage",
    "check-coverage": true,
    "lines": 85,
    "branches": 85,
    "functions": 85,
    "statements": 85
  },
  "optionalDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@openai/codex-sdk": "^0.135.0",
    "@opencode-ai/sdk": "^1.15.12"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "pg": "^8.13.1",
    "next": "16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
